# BEGIN framework env (managed by fastmcp-template — ORG-PLAN-086 §4)
# Vars inside this block are CHROME: the 3-way merge keeps them current on
# `copier update`. Add your DOMAIN env vars BELOW the END marker — those are
# project-owned and never touched.
FASTMCP_TRANSPORT=http
FASTMCP_HOST=127.0.0.1
FASTMCP_PORT=8000
MCP_DEV_MODE=false
LOG_LEVEL=INFO

# Production (Azure Container Apps) values are set in the Dockerfile, not here:
#   FASTMCP_TRANSPORT=streamable-http
#   FASTMCP_HOST=0.0.0.0
#   FASTMCP_PORT=8080

# OAuth (Microsoft Entra ID) — disabled by default.
# Flip OAUTH_ENABLE=true and fill the rest to require browser-based Azure
# login on HTTP/SSE transports. See README "OAuth (Microsoft Entra ID)" for
# Azure App Registration steps.
OAUTH_ENABLE=false
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_TENANT_ID=
# OAUTH_BASE_URL=http://localhost:8000
# OAUTH_REQUIRED_SCOPES=mcp.access

# Durable sessions (production): NO env vars needed. FastMCP derives its keys
# from the stable client secret; durability is a persistent Azure Files mount at
# FastMCP's home path, provisioned by Terraform (`oauth_sessions = "files"`).
# See azure_aca/README.md → OAuth. Locally, the default store needs no config.

# END framework env

# --- Domain env (project-owned; add your vars below) ---
STROMY_PG_DSN=postgresql://user:password@localhost:5432/stromy_runtime
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-Stromy
AZURE_RUNNER_JOB=stromy-runner
CLIENT_ROLE_PREFIX=client.
OPERATOR_ROLE=operator
# Local/test bootstrap only; production uses verified Entra roles.
# CLIENT_SCOPE_MAP=<verified-sub-guid>=dukestrategies
